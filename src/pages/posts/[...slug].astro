---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
    return [
        { params: { slug: 'my-first-track' } }
    ];
}

const { slug } = Astro.params;

const postData = {
    title: "Первый пост",
    date: "22 апреля 2026",
    content: `
        <p>Всем привет. Запускаю блог.</p>
        <p>Тут будут мысли о музыке, творчестве, технике, вдохновении. Иногда — просто настроение.</p>
        <p>Первый трек уже выложил на SoundCloud. Ссылка на плеере выше.</p>
        <p>Посмотрим, что из этого выйдет. Мне самому интересно.</p>
        <p>ZHAR</p>
    `
};
---

<Layout title={`ZHAR — ${postData.title}`}>
    <Header />
    
    <article class="post-full">
        <h1>{postData.title}</h1>
        <div class="post-meta">{postData.date}</div>
        <div class="post-content" set:html={postData.content} />
    </article>

    <Footer />

    <style>
        .post-full {
            max-width: 100%;
        }
        .post-full h1 {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }
        .post-meta {
            color: var(--gray);
            margin-bottom: 2rem;
            font-size: 0.9rem;
        }
        .post-content {
            color: var(--gray);
            line-height: 1.6;
        }
        .post-content p {
            margin-bottom: 1rem;
        }
    </style>
</Layout>