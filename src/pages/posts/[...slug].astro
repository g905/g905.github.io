---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Получаем все посты напрямую
export async function getStaticPaths() {
    // Импортируем все .md файлы
    const posts = await Astro.glob('../../content/posts/*.md');
    
    // Сортируем (необязательно, но для порядка)
    posts.sort((a, b) => new Date(b.frontmatter.date) - new Date(a.frontmatter.date));
    
    // Возвращаем пути для каждого поста
    return posts.map((post) => {
        // Извлекаем slug из полного пути к файлу
        const filePath = post.file;
        const slug = filePath.split('/').pop().replace('.md', '');
        
        return {
            params: { slug },
            props: { post },
        };
    });
}

// Получаем пропс из getStaticPaths
const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={`ZHAR — ${post.frontmatter.title}`}>
    <Header />
    
    <article class="post-full">
        <h1>{post.frontmatter.title}</h1>
        <div class="post-meta">{post.frontmatter.date}</div>
        <div class="post-content">
            <Content />
        </div>
    </article>

    <Footer />

    <style>
        .post-full {
            max-width: 100%;
        }
        .post-full h1 {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }
        .post-meta {
            color: var(--gray);
            margin-bottom: 2rem;
            font-size: 0.9rem;
        }
        .post-content {
            color: var(--gray);
            line-height: 1.6;
        }
        .post-content p {
            margin-bottom: 1rem;
        }
        .post-content img {
            max-width: 100%;
            height: auto;
            border-radius: 0.5rem;
        }
    </style>
</Layout>
