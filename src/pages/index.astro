---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Импортируем все посты из папки src/content/posts
const allPosts = await Astro.glob('../../content/posts/*.md');

// Сортируем посты по дате (новые сверху)
const sortedPosts = allPosts.sort((a, b) => 
    new Date(b.frontmatter.date) - new Date(a.frontmatter.date)
);

export async function getStaticPaths() {
    return sortedPosts.map((post) => ({
        params: { slug: post.url.split('/').pop().replace('.html', '') },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={`ZHAR — ${post.frontmatter.title}`}>
    <Header />
    
    <article class="post-full">
        <h1>{post.frontmatter.title}</h1>
        <div class="post-meta">{post.frontmatter.date}</div>
        <div class="post-content">
            <Content />
        </div>
    </article>

    <Footer />

    <style>
        .post-full {
            max-width: 100%;
        }
        .post-full h1 {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }
        .post-meta {
            color: var(--gray);
            margin-bottom: 2rem;
            font-size: 0.9rem;
        }
        .post-content {
            color: var(--gray);
            line-height: 1.6;
        }
        .post-content p {
            margin-bottom: 1rem;
        }
    </style>
</Layout>
