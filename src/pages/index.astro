---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';

// Получаем все посты
const allPosts = await Astro.glob('../content/posts/*.md');

// Сортируем по дате (новые сверху)
const posts = allPosts.sort((a, b) => 
    new Date(b.frontmatter.date) - new Date(a.frontmatter.date)
);
---

<Layout title="ZHAR — музыкальный блог">
    <Header />
    
    <section class="hero">
        <h1>музыка и мысли</h1>
        <p>поп-панк, электроника, брейкбит. и немного слов.</p>
    </section>

    <section class="posts">
        {
            posts.map((post) => {
                // Извлекаем slug из пути к файлу
                const filePath = post.file;
                const slug = filePath.split('/').pop().replace('.md', '');
                
                return (
                    <PostCard post={{
                        title: post.frontmatter.title,
                        date: post.frontmatter.date,
                        excerpt: post.frontmatter.excerpt || post.frontmatter.description || "Читать далее...",
                        link: `/posts/${slug}`
                    }} />
                );
            })
        }
    </section>

    <Footer />

    <style>
        .hero {
            margin-bottom: 3rem;
        }
        .hero h1 {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 0.75rem;
            background: linear-gradient(135deg, var(--text) 0%, var(--accent) 100%);
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .hero p {
            color: var(--gray);
            font-size: 1.1rem;
        }
        @media (max-width: 600px) {
            .hero h1 {
                font-size: 2rem;
            }
        }
    </style>
</Layout>
