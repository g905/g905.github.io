<body>
    <div class="container fade-in">
        <slot />
    </div>
</body>
</html>

<style>
/* Глобальные стили для изображений в контенте */
.post-content img {
    max-width: 100%;
    height: auto;
    border-radius: 12px;
    margin: 1.5rem auto;
