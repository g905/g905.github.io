---
export interface Props {
    trackUrl?: string;
    trackTitle?: string;
    trackArtist?: string;
}

const { 
    trackUrl = "https://api.soundcloud.com/tracks/soundcloud%253Atracks%253A1073141641", 
    trackTitle = "P5", 
    trackArtist = "Pender Bender" 
} = Astro.props;
---

<div class="track-card">
    <div class="track-info">
        <div class="track-title">{trackTitle}</div>
        <div class="track-meta">{trackArtist} · 2021</div>
    </div>
    <iframe 
        width="100%" 
        height="300" 
        scrolling="no" 
        frameborder="no" 
        allow="autoplay" 
        src={`https://w.soundcloud.com/player/?url=${encodeURIComponent(trackUrl)}&color=%23ff5500&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true&visual=true`}>
    </iframe>
    <div class="soundcloud-attribution">
        <a href="https://soundcloud.com/pender-bender" target="_blank" rel="noopener noreferrer">{trackArtist}</a> · 
        <a href="https://soundcloud.com/pender-bender/p5-1" target="_blank" rel="noopener noreferrer">{trackTitle}</a>
    </div>
</div>

<style>
    .track-card {
        background: var(--card-bg);
        border-radius: 1rem;
        padding: 1.5rem;
        border: 1px solid var(--border);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .track-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    }
    .track-info {
        margin-bottom: 1rem;
    }
    .track-title {
        font-size: 1.3rem;
        font-weight: 600;
        margin-bottom: 0.25rem;
    }
    .track-meta {
        font-size: 0.8rem;
        color: var(--gray);
    }
    .soundcloud-attribution {
        font-size: 10px;
        color: #cccccc;
        margin-top: 0.5rem;
        text-align: center;
    }
    .soundcloud-attribution a {
        color: #cccccc;
    }
    .soundcloud-attribution a:hover {
        color: var(--accent);
    }
</style>